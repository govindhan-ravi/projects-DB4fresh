# Frontend Dockerfile (Dockerfile.frontend)
FROM node:20-alpine AS builder
WORKDIR /app

# Install dependencies (root package.json includes frontend deps)
COPY package*.json ./
RUN npm ci --only=production

# Copy all source files (including src folder) and build
COPY . ./
RUN npm run build

# Runtime stage using nginx to serve the built assets
FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;" ]
