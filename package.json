{
  "name": "zepto-advanced-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "echo \"No lint configured\"",
    "test": "echo \"No tests configured\"",
    "zookeeper": "cd /d C:\\kafka\\kafka_2.13-3.9.2 && .\\bin\\windows\\zookeeper-server-start.bat .\\config\\zookeeper.properties",
    "kafka": "cd /d C:\\kafka\\kafka_2.13-3.9.2 && .\\bin\\windows\\kafka-server-start.bat .\\config\\server.properties",
    "backend": "cd backend && npm run dev",
    "frontend": "npm run dev",
    "start-all": "concurrently -k -n \"ZK,KAFKA,BE,FE\" -c \"yellow,blue,green,magenta\" \"npm run zookeeper\" \"powershell -Command Start-Sleep -Seconds 5; npm run kafka\" \"powershell -Command Start-Sleep -Seconds 12; npm run backend\" \"powershell -Command Start-Sleep -Seconds 12; npm run frontend\""
  },
